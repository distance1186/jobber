# ── Database ──────────────────────────────────────────
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=jobtracking

# ── Ollama LLM ────────────────────────────────────────
# Recommended models by system RAM:
#   <8 GB  → phi4-mini or qwen3:4b
#   8-16 GB → mistral-small3
#   16-32 GB → llama3.3 (default)
#   32+ GB → gemma3:12b
OLLAMA_MODEL=llama3.3
OLLAMA_BASE_URL=http://ollama:11434

# ── LinkedIn Authentication ───────────────────────────
# Retrieve from browser DevTools > Application > Cookies > li_at
LI_AT_COOKIE=PASTE_YOUR_LI_AT_COOKIE_HERE

# ── Dashboard (JobSync) ──────────────────────────────
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Notifications (Apprise URL format) ────────────────
# Examples:
#   mailtos://user:pass@smtp.example.com?to=you@email.com
#   gotify://YOUR_HOST/YOUR_APP_TOKEN
#   ntfy://YOUR_HOST/job-tracker-topic
NOTIFY_URLS=
NOTIFY_MIN_SCORE=7

# ── Scraper Schedule (cron syntax) ────────────────────
SCRAPE_SCHEDULE=0 7,12,18 * * *
